# ============================
# IntelMeet — MERN Stack .gitignore
# ============================

# ----- Node Modules -----
node_modules/
**/node_modules/

# ----- Environment Variables (NEVER upload these!) -----
.env
.env.local
.env.development
.env.production
.env.staging
**/.env
**/.env.local
**/.env.production
backend/.env
frontend/.env

# ----- Build Output -----
dist/
build/
.vite/
**/dist/
**/build/

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
backend/logs/

# ----- Uploaded / Media Files -----
backend/uploads/
uploads/
*.mp4
*.webm
*.mov
*.avi
*.mkv

# ----- OS Files -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- IDE / Editor -----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ----- Package Manager Locks (Keep lock files for consistency) -----
# package-lock.json (Keep this)
yarn.lock
pnpm-lock.yaml

# ----- Testing -----
coverage/
.nyc_output/

# ----- Runtime / Cache -----
.cache/
.parcel-cache/
.npm/
*.tsbuildinfo

# ----- Docker -----
.docker/

# ----- Misc -----
*.pem
*.key
*.cert
*.p12
.vercel
.netlify
