# Production Environment Variables for Render / VPS
PORT=5000
NODE_ENV=production

# MongoDB Atlas Database URI (Do not use localhost in production)
# Example: mongodb+srv://username:password@cluster.mongodb.net/intellimeet?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_connection_string

# Secret key for signing JWT tokens (use a long, cryptographically strong random string)
# You can generate one via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_production_jwt_secret

# The URL of your deployed frontend (e.g. on Vercel)
# IMPORTANT: This must match your Vercel URL exactly (without trailing slash) for CORS to work
FRONTEND_URL=https://your-app-name.vercel.app

# --- OPTIONAL INTEGRATIONS ---

# AI Service (Local Ollama URL if hosted on your server, or fallback)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3

# Google OAuth (If using social login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email SMTP (For password recovery functionality)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Cloudinary Credentials (For storing user uploaded files or meeting recordings)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# OpenAI API Key (Required for AI summaries if Ollama is not used in production)
OPENAI_API_KEY=your_openai_api_key
