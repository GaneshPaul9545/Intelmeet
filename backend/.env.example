PORT=5000
MONGODB_URI=
JWT_SECRET=change_this_to_a_strong_random_secret
FRONTEND_URL=http://localhost:5173

# AI Service (Ollama local LLM - install from https://ollama.ai)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3

# Google OAuth (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email SMTP (For Password Reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Cloudinary (For Video Recording Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OpenAI (For AI Summary and Transcription fallback if needed)
OPENAI_API_KEY=your_openai_api_key